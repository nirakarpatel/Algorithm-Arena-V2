{
  "openapi": "3.0.3",
  "info": {
    "title": "Algorithm Arena API",
    "version": "1.1.0",
    "description": "API contract for Algorithm Arena platform."
  },
  "servers": [
    {
      "url": "http://localhost:5000"
    }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Register a new user"
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Authenticate user and return token"
      }
    },
    "/api/auth/me": {
      "get": {
        "summary": "Get current authenticated user"
      }
    },
    "/api/auth/refresh": {
      "post": {
        "summary": "Rotate refresh token and issue new access token"
      }
    },
    "/api/auth/logout": {
      "post": {
        "summary": "Logout current session"
      }
    },
    "/api/auth/logout-all": {
      "post": {
        "summary": "Logout all sessions for current user"
      }
    },
    "/api/challenges": {
      "get": {
        "summary": "List challenges with query filters"
      },
      "post": {
        "summary": "Create challenge (admin)"
      }
    },
    "/api/challenges/{id}": {
      "get": {
        "summary": "Get challenge by id"
      },
      "put": {
        "summary": "Update challenge (admin)"
      },
      "delete": {
        "summary": "Delete challenge (admin)"
      }
    },
    "/api/clans": {
      "get": {
        "summary": "List clans for the current user"
      },
      "post": {
        "summary": "Create clan (admin)"
      }
    },
    "/api/clans/leaderboard": {
      "get": {
        "summary": "List clan leaderboard with timeframe and status filters",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["active", "archived", "all"]
            }
          },
          {
            "name": "window",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["all", "7d", "30d"]
            }
          }
        ]
      }
    },
    "/api/clans/mine": {
      "get": {
        "summary": "Get the current user's clan"
      }
    },
    "/api/clans/{id}": {
      "get": {
        "summary": "Get clan by id"
      },
      "put": {
        "summary": "Update clan (admin)"
      },
      "patch": {
        "summary": "Reserved for clan lifecycle operations"
      },
      "delete": {
        "summary": "Delete archived clan permanently (admin)"
      }
    },
    "/api/clans/{id}/archive": {
      "patch": {
        "summary": "Archive clan (chief or admin)"
      }
    },
    "/api/clans/{id}/restore": {
      "patch": {
        "summary": "Restore archived clan (admin)"
      }
    },
    "/api/clans/{id}/join": {
      "post": {
        "summary": "Join clan"
      }
    },
    "/api/clans/{id}/leave": {
      "post": {
        "summary": "Leave clan"
      }
    },
    "/api/clans/{id}/approve/{userId}": {
      "post": {
        "summary": "Approve clan join request"
      }
    },
    "/api/clans/{id}/reject/{userId}": {
      "post": {
        "summary": "Reject clan join request"
      }
    },
    "/api/clans/{id}/notices": {
      "post": {
        "summary": "Add clan notice"
      }
    },
    "/api/clans/{id}/notices/{index}": {
      "delete": {
        "summary": "Remove clan notice"
      }
    },
    "/api/clans/{id}/admin-stats": {
      "get": {
        "summary": "Get clan admin stats"
      }
    },
    "/api/clans/{id}/chief": {
      "put": {
        "summary": "Assign clan chief (admin)"
      }
    },
    "/api/clans/{id}/members": {
      "post": {
        "summary": "Add clan member (admin)"
      }
    },
    "/api/clans/{id}/members/{userId}": {
      "delete": {
        "summary": "Remove clan member"
      }
    },
    "/api/submissions": {
      "get": {
        "summary": "List submissions (admin)"
      },
      "post": {
        "summary": "Create submission"
      }
    },
    "/api/submissions/my-submissions": {
      "get": {
        "summary": "List current user's submissions"
      }
    },
    "/api/submissions/leaderboard": {
      "get": {
        "summary": "Leaderboard with timeframe and pagination"
      }
    },
    "/api/submissions/{id}": {
      "get": {
        "summary": "Get submission by id (owner/admin)"
      },
      "put": {
        "summary": "Update submission status (admin)"
      }
    },
    "/api/dashboard/summary": {
      "get": {
        "summary": "Get dashboard summary for authenticated user"
      }
    },
    "/api/profile/stats": {
      "get": {
        "summary": "Get profile statistics for authenticated user"
      }
    }
  }
}
